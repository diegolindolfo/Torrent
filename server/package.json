{
  "name": "@torrent-player/server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend para o Torrent Player — WebTorrent híbrido + streaming HTTP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.12.0",
    "@types/webtorrent": "^0.110.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
